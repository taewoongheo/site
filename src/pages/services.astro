---
import "@/styles/global.css";
import * as Constants from "@/lib/consts";

const title = "TAEWOONG HEO — Services";
const description =
  "App Development & Technical Consulting by TAEWOONG HEO";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&family=Work+Sans:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
  </head>

  <body>
    <!-- Navigation -->
    <nav class="nav">
      <a href="/" class="nav-logo">tw.heo</a>
      <div class="nav-links">
        <a href="#services">Services</a>
        <a href="#difference">Difference</a>
        <a href="#works">Works</a>
        <a href="#contact">Contact</a>
      </div>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <p class="hero-label">TAEWOONG HEO — App Development & Consulting</p>
        <h1 class="hero-title">
          앱의 완성도를<br />끌어올리는 개발
        </h1>
        <p class="hero-sub">
          같은 기능, 같은 일정, 같은 가격.<br />
          다른 건 결과물의 퀄리티입니다.
        </p>
        <a href="#contact" class="hero-cta">프로젝트 문의 ↓</a>
      </div>
    </section>

    <!-- Services -->
    <section id="services" class="section">
      <div class="container">
        <h2 class="section-label">Services</h2>
        <div class="services-grid">
          <div class="service-card">
            <span class="service-num">01</span>
            <h3 class="service-title">Mobile App</h3>
            <p class="service-desc">
              React Native 기반 iOS, Android 크로스플랫폼 앱 개발.
              바텀시트, 화면 전환, 버튼 피드백 등 기본 인터랙션이 포함된 결과물을 제공합니다.
            </p>
          </div>
          <div class="service-card">
            <span class="service-num">02</span>
            <h3 class="service-title">Web App</h3>
            <p class="service-desc">
              Next.js 기반 반응형 웹 애플리케이션 개발.
              빠른 로딩, 접근성, 인터랙션까지 고려한 웹 경험을 구축합니다.
            </p>
          </div>
          <div class="service-card">
            <span class="service-num">03</span>
            <h3 class="service-title">Consulting</h3>
            <p class="service-desc">
              아키텍처 설계, 성능 최적화, 코드 리뷰.
              기술적 의사결정에 대한 자문을 제공합니다.
            </p>
          </div>
        </div>
        <p class="services-note">
          * 디자인 시안이 없는 소규모 프로젝트의 경우, UI/UX 디자인을 함께 제안드릴 수 있습니다.
        </p>
      </div>
    </section>

    <!-- Difference -->
    <section id="difference" class="section">
      <div class="container">
        <h2 class="section-label">The Difference</h2>
        <p class="difference-heading">
          같은 기능인데 느낌이 다릅니다
        </p>
        <p class="difference-sub">
          인터랙션 하나로 사용자가 느끼는 앱의 품질이 달라집니다.<br />
          추가 비용 없이, 기본에 포함된 디테일입니다.
        </p>
        <div class="comparison-grid">
          <!-- Before/After 비교: GIF를 직접 넣어주세요 -->
          <!-- src/assets/images/comparison/ 에 GIF 추가 후 <img> 로 교체 -->
          <div class="comparison-item">
            <div class="comparison-pair">
              <div class="comparison-cell">
                <div class="comparison-thumb">
                  <span class="work-placeholder">Before GIF</span>
                </div>
                <span class="comparison-label">Without</span>
              </div>
              <div class="comparison-cell">
                <div class="comparison-thumb">
                  <span class="work-placeholder">After GIF</span>
                </div>
                <span class="comparison-label">With Interaction</span>
              </div>
            </div>
            <p class="comparison-caption">화면 전환</p>
          </div>
          <div class="comparison-item">
            <div class="comparison-pair">
              <div class="comparison-cell">
                <div class="comparison-thumb">
                  <span class="work-placeholder">Before GIF</span>
                </div>
                <span class="comparison-label">Without</span>
              </div>
              <div class="comparison-cell">
                <div class="comparison-thumb">
                  <span class="work-placeholder">After GIF</span>
                </div>
                <span class="comparison-label">With Interaction</span>
              </div>
            </div>
            <p class="comparison-caption">버튼 피드백</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Process -->
    <section id="process" class="section">
      <div class="container">
        <h2 class="section-label">Process</h2>
        <div class="process-grid">
          <div class="process-step">
            <span class="process-num">01</span>
            <h3 class="process-title">상담</h3>
            <p class="process-desc">
              프로젝트의 목표, 범위, 일정을 파악합니다.
              디자인 시안이 있으면 공유해 주세요.
            </p>
          </div>
          <div class="process-step">
            <span class="process-num">02</span>
            <h3 class="process-title">견적 · 일정</h3>
            <p class="process-desc">
              기능 명세를 기반으로 견적과 일정을 산출합니다.
              합의 후 계약을 진행합니다.
            </p>
          </div>
          <div class="process-step">
            <span class="process-num">03</span>
            <h3 class="process-title">개발</h3>
            <p class="process-desc">
              주 단위로 진행 상황을 공유합니다.
              중간 확인을 통해 방향을 조율합니다.
            </p>
          </div>
          <div class="process-step">
            <span class="process-num">04</span>
            <h3 class="process-title">납품 · 배포</h3>
            <p class="process-desc">
              최종 검수 후 앱스토어 배포 또는 소스코드를 전달합니다.
              배포 후 일정 기간 유지보수를 지원합니다.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Works / Portfolio -->
    <section id="works" class="section">
      <div class="container">
        <h2 class="section-label">Selected Works</h2>
        <div class="works-grid">
          <!-- 포트폴리오 아이템: 이미지 + 제목 + 설명 구조 -->
          <!-- 이미지는 16:9 비율, src/assets/images/works/ 에 추가 -->
          <a class="work-item" href="#">
            <div class="work-thumb">
              <span class="work-placeholder">Image</span>
            </div>
            <div class="work-info">
              <h3 class="work-title">Project Title</h3>
              <p class="work-tag">Mobile App — 2025</p>
            </div>
          </a>
          <a class="work-item" href="#">
            <div class="work-thumb">
              <span class="work-placeholder">Image</span>
            </div>
            <div class="work-info">
              <h3 class="work-title">Project Title</h3>
              <p class="work-tag">Web App — 2025</p>
            </div>
          </a>
          <a class="work-item" href="#">
            <div class="work-thumb">
              <span class="work-placeholder">Image</span>
            </div>
            <div class="work-info">
              <h3 class="work-title">Project Title</h3>
              <p class="work-tag">Consulting — 2025</p>
            </div>
          </a>
          <a class="work-item" href="#">
            <div class="work-thumb">
              <span class="work-placeholder">Image</span>
            </div>
            <div class="work-info">
              <h3 class="work-title">Project Title</h3>
              <p class="work-tag">Mobile App — 2024</p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- About / Legal Entity -->
    <section id="about" class="section">
      <div class="container">
        <h2 class="section-label">About</h2>
        <div class="about-grid">
          <div class="about-text">
            <p>
              React Native와 Next.js를 다루는 소프트웨어 엔지니어입니다.
              기능이 동작하는 것에서 멈추지 않고, 인터랙션과 디테일까지
              신경 쓴 결과물을 만듭니다.
            </p>
            <div class="about-stack">
              <span class="stack-label">Tech Stack</span>
              <div class="stack-list">
                <span>React</span>
                <span>Next.js</span>
                <span>React Native</span>
                <span>AWS</span>
                <span>Supabase</span>
              </div>
            </div>
            <div class="about-links">
              <a href="https://twheo.dev/blog" class="about-link">
                Blog — 기술 딥다이브 ↗
              </a>
              <a href="https://github.com/taewoongheo" class="about-link">
                GitHub ↗
              </a>
            </div>
          </div>
          <div class="about-info">
            <dl class="info-list">
              <div class="info-row">
                <dt>Legal Entity</dt>
                <dd>TAEWOONG HEO</dd>
              </div>
              <div class="info-row">
                <dt>Business</dt>
                <dd>Application Software Development & Supply</dd>
              </div>
              <div class="info-row">
                <dt>Website</dt>
                <dd><a href="https://twheo.dev">twheo.dev</a></dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="section section-contact">
      <div class="container contact-container">
        <h2 class="contact-heading">Let's Work<br />Together</h2>
        <p class="contact-desc">
          프로젝트에 대해 이야기해 보세요.
        </p>
        <!-- TODO: 도메인 이메일 확보 후 교체 -->
        <a id="contact-email" class="contact-email"></a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-business">
          <span>TAEWOONG HEO</span>
          <span class="footer-sep">·</span>
          <span>Application Software Development & Supply</span>
          <span class="footer-sep">·</span>
          <a href="https://twheo.dev">twheo.dev</a>
        </div>
        <span class="footer-copy">© 2026 TAEWOONG HEO</span>
      </div>
    </footer>

    <script>
      // 이메일 봇 스크래핑 방지
      const a = document.getElementById("contact-email");
      if (a) {
        // TODO: 도메인 이메일 확보 후 교체
        const e = ["tw.heo24", "gmail.com"].join("@");
        (a as HTMLAnchorElement).href = "mailto:" + e;
        a.textContent = e;
      }
    </script>

    <style>
      /* ===== Reset & Base ===== */
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Work Sans", sans-serif;
        background: #fafaf9;
        color: #1c1917;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      html {
        scroll-behavior: smooth;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
      }

      @media (min-width: 768px) {
        .container {
          padding: 0 48px;
        }
      }

      /* ===== Navigation ===== */
      .nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px 32px;
        background: rgba(250, 250, 249, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid #e7e5e4;
      }

      .nav-logo {
        font-family: "IBM Plex Mono", monospace;
        font-size: 14px;
        font-weight: 500;
        letter-spacing: 0.05em;
        color: #1c1917;
      }

      .nav-links {
        display: flex;
        gap: 28px;
      }

      .nav-links a {
        font-size: 13px;
        font-weight: 400;
        color: #78716c;
        letter-spacing: 0.02em;
        transition: color 0.2s;
        padding: 4px 0;
      }

      .nav-links a:hover {
        color: #1c1917;
      }

      /* ===== Hero ===== */
      .hero {
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding: 120px 48px 80px;
      }

      .hero-inner {
        max-width: 1200px;
        margin: 0 auto;
        width: 100%;
      }

      .hero-label {
        font-family: "IBM Plex Mono", monospace;
        font-size: 13px;
        font-weight: 400;
        color: #78716c;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 32px;
      }

      .hero-title {
        font-size: clamp(36px, 8vw, 80px);
        font-weight: 800;
        line-height: 1.15;
        letter-spacing: -0.03em;
        color: #1c1917;
        margin-bottom: 32px;
      }

      .hero-sub {
        font-size: 16px;
        line-height: 1.7;
        color: #57534e;
        max-width: 400px;
        margin-bottom: 48px;
      }

      .hero-cta {
        display: inline-block;
        font-family: "IBM Plex Mono", monospace;
        font-size: 13px;
        font-weight: 500;
        color: #1c1917;
        padding: 14px 28px;
        border: 1px solid #a8a29e;
        border-radius: 0;
        letter-spacing: 0.04em;
        transition: background 0.2s, border-color 0.2s;
      }

      .hero-cta:hover {
        background: #1c1917;
        color: #fafaf9;
        border-color: #1c1917;
      }

      /* ===== Sections ===== */
      .section {
        padding: 100px 0;
        border-top: 1px solid #e7e5e4;
      }

      .section:nth-child(even) {
        padding: 120px 0;
      }

      .section-label {
        font-family: "IBM Plex Mono", monospace;
        font-size: 12px;
        font-weight: 500;
        color: #78716c;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 56px;
      }

      /* ===== Services ===== */
      .services-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1px;
        background: #e7e5e4;
      }

      @media (min-width: 768px) {
        .services-grid {
          grid-template-columns: repeat(3, 1fr);
        }
      }

      .service-card {
        background: #fafaf9;
        padding: 40px 32px;
        transition: background 0.3s;
      }

      .service-card:hover {
        background: #f5f5f4;
      }

      .service-num {
        font-family: "IBM Plex Mono", monospace;
        font-size: 12px;
        color: #a8a29e;
        display: block;
        margin-bottom: 24px;
      }

      .service-title {
        font-size: 20px;
        font-weight: 600;
        color: #1c1917;
        margin-bottom: 16px;
        line-height: 1.3;
      }

      .service-desc {
        font-size: 14px;
        line-height: 1.7;
        color: #57534e;
      }

      .services-note {
        font-family: "IBM Plex Mono", monospace;
        font-size: 12px;
        color: #78716c;
        margin-top: 24px;
      }

      /* ===== Difference ===== */
      .difference-heading {
        font-size: clamp(24px, 4vw, 36px);
        font-weight: 700;
        color: #1c1917;
        margin-bottom: 16px;
        letter-spacing: -0.02em;
      }

      .difference-sub {
        font-size: 15px;
        line-height: 1.7;
        color: #57534e;
        margin-bottom: 56px;
        max-width: 500px;
      }

      .comparison-grid {
        display: flex;
        flex-direction: column;
        gap: 48px;
      }

      .comparison-item {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .comparison-pair {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
      }

      .comparison-cell {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .comparison-thumb {
        aspect-ratio: 9 / 16;
        max-height: 480px;
        background: #f5f5f4;
        border: 1px solid #e7e5e4;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }

      .comparison-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .comparison-label {
        font-family: "IBM Plex Mono", monospace;
        font-size: 11px;
        color: #78716c;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .comparison-caption {
        font-size: 14px;
        font-weight: 500;
        color: #44403c;
      }

      /* ===== Process ===== */
      .process-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1px;
        background: #e7e5e4;
      }

      @media (min-width: 768px) {
        .process-grid {
          grid-template-columns: repeat(4, 1fr);
        }
      }

      .process-step {
        background: #fafaf9;
        padding: 40px 32px;
      }

      .process-num {
        font-family: "IBM Plex Mono", monospace;
        font-size: 12px;
        color: #a8a29e;
        display: block;
        margin-bottom: 20px;
      }

      .process-title {
        font-size: 18px;
        font-weight: 600;
        color: #1c1917;
        margin-bottom: 12px;
      }

      .process-desc {
        font-size: 14px;
        line-height: 1.7;
        color: #57534e;
      }

      /* ===== Works ===== */
      .works-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 24px;
      }

      @media (min-width: 768px) {
        .works-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      .work-item {
        display: block;
        text-decoration: none;
        transition: opacity 0.3s;
      }

      .work-item:hover {
        opacity: 0.8;
      }

      .work-thumb {
        aspect-ratio: 16 / 9;
        background: #f5f5f4;
        border: 1px solid #e7e5e4;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        margin-bottom: 16px;
      }

      .work-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .work-placeholder {
        font-family: "IBM Plex Mono", monospace;
        font-size: 13px;
        color: #a8a29e;
      }

      .work-info {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 16px;
      }

      .work-title {
        font-size: 16px;
        font-weight: 500;
        color: #1c1917;
      }

      .work-tag {
        font-family: "IBM Plex Mono", monospace;
        font-size: 12px;
        color: #78716c;
        white-space: nowrap;
      }

      /* ===== About ===== */
      .about-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 64px;
      }

      @media (min-width: 768px) {
        .about-grid {
          grid-template-columns: 1fr 1fr;
        }
      }

      .about-text p {
        font-size: 18px;
        line-height: 1.8;
        color: #44403c;
      }

      .about-stack {
        margin-top: 32px;
      }

      .stack-label {
        font-family: "IBM Plex Mono", monospace;
        font-size: 11px;
        font-weight: 500;
        color: #78716c;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        display: block;
        margin-bottom: 12px;
      }

      .stack-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .stack-list span {
        font-family: "IBM Plex Mono", monospace;
        font-size: 12px;
        color: #44403c;
        padding: 5px 12px;
        border: 1px solid #d6d3d1;
      }

      .about-links {
        margin-top: 28px;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .about-link {
        font-family: "IBM Plex Mono", monospace;
        font-size: 13px;
        color: #44403c;
        text-decoration: underline;
        text-underline-offset: 3px;
        transition: color 0.2s;
      }

      .about-link:hover {
        color: #1c1917;
      }

      .info-list {
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .info-row {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 20px 0;
        border-bottom: 1px solid #e7e5e4;
      }

      .info-row:first-child {
        padding-top: 0;
      }

      .info-row dt {
